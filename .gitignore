# ═══════════════════════════════════════════════════════
#  Android / Gradle 构建产物
# ═══════════════════════════════════════════════════════
**/build/
**/.gradle/
**/.cxx/

# ═══════════════════════════════════════════════════════
#  Android Studio IDE 文件
#  保留：.idea/gradle.xml, misc.xml（项目配置）
#  忽略：workspace、缓存、个人配置
# ═══════════════════════════════════════════════════════
**/.idea/workspace.xml
**/.idea/caches/
**/.idea/deploymentTargetSelector.xml
**/.idea/runConfigurations.xml
**/.idea/studiobot.xml
**/.idea/migrations.xml
**/.idea/compiler.xml
**/.idea/AndroidProjectSystem.xml
*.iml

# ═══════════════════════════════════════════════════════
#  本地配置（包含 SDK 路径，每台机器不同）
# ═══════════════════════════════════════════════════════
local.properties

# ═══════════════════════════════════════════════════════
#  https-server 编译产物和运行时数据
# ═══════════════════════════════════════════════════════
# 编译出的可执行文件
https-server/server

# 运行时上传的 so 和密钥文件（敏感数据，不入库）
https-server/uploads/keys/

# TLS 证书和私钥（敏感，不入库）
https-server/certs/cert.pem
https-server/certs/key.pem

# ═══════════════════════════════════════════════════════
#  macOS 系统文件
# ═══════════════════════════════════════════════════════
.DS_Store
**/.DS_Store

# ═══════════════════════════════════════════════════════
#  Kotlin / Java 编译缓存
# ═══════════════════════════════════════════════════════
*.class
*.jar

# ═══════════════════════════════════════════════════════
#  NDK / CMake 临时文件
# ═══════════════════════════════════════════════════════
*.o
*.so
*.a
CMakeCache.txt
CMakeFiles/

# ═══════════════════════════════════════════════════════
#  Android 编译产物和调试文件
# ═══════════════════════════════════════════════════════
*.dex
*.apk
*.ap_
*.aab

# Heap dumps（内存转储文件，通常很大）
*.hprof

# Proguard 混淆映射
proguard/
mapping.txt

# Log files
*.log
